{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/crawler-user-agent/layout,_N_T_/crawler-user-agent/page,_N_T_/crawler-user-agent"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/crawler-user-agent/__PAGE__",
    "/crawler-user-agent",
    "/_index",
    "/_head"
  ]
}